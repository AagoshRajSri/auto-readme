# auto-readme environment configuration
# Rename this file to .env or set these in your shell environment

# ==========================================================
# LLM Provider API Keys (Set at least one)
# ==========================================================

# Required if using provider="gemini" (Default)
GEMINI_API_KEY="your_google_gemini_api_key_here"

# Required if using provider="openai"
OPENAI_API_KEY="your_openai_api_key_here"

# Required if using provider="anthropic"
ANTHROPIC_API_KEY="your_anthropic_api_key_here"

# ==========================================================
# CLI Default Overrides (Optional)
# ==========================================================

# Set the default LLM provider ("gemini", "openai", "anthropic")
AUTOREADME_LLM_PROVIDER="gemini"

# Override the default LLM model name (e.g. "gemini-2.5-flash", "gpt-4o")
AUTOREADME_LLM_MODEL=""
